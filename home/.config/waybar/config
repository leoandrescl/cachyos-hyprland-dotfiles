{
  "layer": "top",
  "position": "top",
  "mode": "dock",
  "exclusive": true,
  "passthrough": false,
  "height": 36,
  "spacing": 0,
  "margin-top": 10,
  "margin-left": 14,
  "margin-right": 14,

  "modules-left": ["hyprland/workspaces", "custom/current_ws"],
  "modules-center": ["clock"],
  "modules-right": ["network", "pulseaudio", "battery"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{id}",
  },

  "custom/current_ws": {
    "exec": "sh -c \"hyprctl activeworkspace | sed -n 's/.*workspace ID \\([0-9]\\+\\).*/WS \\1/p'\"",
    "interval": 2,
    "tooltip": false
  },

  "clock": {
    "interval": 1,
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %e de %B de %Y}",
    "tooltip": true
  },

  "network": {
    "format-wifi": "NET",
    "format-ethernet": "ETH",
    "format-disconnected": "OFF",
    "tooltip-format-wifi": "{essid} · {signalStrength}%",
    "tooltip-format-ethernet": "Ethernet conectado",
    "tooltip-format-disconnected": "Sin conexión",
    "interval": 5,
    "on-click": "/home/lain/.config/hypr/scripts/network-menu.sh",
    "on-click-right": "/home/lain/.config/hypr/scripts/network-panel.sh"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "VOL MUTE",
    "format-bluetooth": "VOL {volume}%",
    "format-bluetooth-muted": "VOL MUTE",
    "tooltip-format": "{desc}",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  "battery": {
    "interval": 30,
    "states": {
      "warning": 25,
      "critical": 12
    },
    "format": "{icon} {capacity}%",
    "format-charging": "CHG {capacity}%",
    "format-plugged": "AC {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-icons": ["▁", "▂", "▃", "▅", "█"],
    "tooltip-format": "{time}"
  }
}
